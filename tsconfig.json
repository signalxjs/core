{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@sigx/runtime-core",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@sigx/cache": ["./packages/cache/src/index.ts"],
      "@sigx/cloudflare": ["./packages/cloudflare/src/index.ts"],
      "@sigx/vercel": ["./packages/vercel/src/index.ts"],
      "@sigx/netlify": ["./packages/netlify/src/index.ts"],
      "@sigx/vite": ["./packages/vite/src/index.ts"],
      "@sigx/vite/islands": ["./packages/vite/src/islands.ts"],
      "@sigx/vite/resume": ["./packages/vite/src/resume.ts"],
      "@sigx/vite/server": ["./packages/vite/src/server-fn.ts"],
      "@sigx/vite/ssr": ["./packages/vite/src/ssr.ts"],
      "@sigx/reactivity": ["./packages/reactivity/src/index.ts"],
      "@sigx/serialize": ["./packages/serialize/src/index.ts"],
      "@sigx/reactivity/internals": ["./packages/reactivity/src/internals.ts"],
      "@sigx/runtime-core": ["./packages/runtime-core/src/index.ts"],
      "@sigx/runtime-core/internals": ["./packages/runtime-core/src/internals.ts"],
      "@sigx/runtime-core/jsx-runtime": ["./packages/runtime-core/src/index.ts"],
      "@sigx/runtime-core/jsx-dev-runtime": ["./packages/runtime-core/src/index.ts"],
      "@sigx/runtime-dom": ["./packages/runtime-dom/src/index.ts"],
      "@sigx/runtime-dom/platform": ["./packages/runtime-dom/src/platform.ts"],
      "@sigx/runtime-dom/internals": ["./packages/runtime-dom/src/internals.ts"],
      "@sigx/server-renderer": ["./packages/server-renderer/src/index.ts"],
      "@sigx/server-renderer/server": ["./packages/server-renderer/src/server/index.ts"],
      "@sigx/server-renderer/node": ["./packages/server-renderer/src/node.ts"],
      "@sigx/server-renderer/client/scheduler": ["./packages/server-renderer/src/client/scheduler.ts"],
      "@sigx/server-renderer/client": ["./packages/server-renderer/src/client/index.ts"],
      "@sigx/resume": ["./packages/resume/src/index.ts"],
      "@sigx/server": ["./packages/server/src/index.ts"],
      "@sigx/server/client": ["./packages/server/src/client/index.ts"],
      "@sigx/server/server": ["./packages/server/src/server/index.ts"],
      "@sigx/server/node": ["./packages/server/src/node.ts"],
      "@sigx/resume/server": ["./packages/resume/src/server/index.ts"],
      "@sigx/resume/client": ["./packages/resume/src/client/index.ts"],
      "@sigx/resume/loader": ["./packages/resume/src/loader/index.ts"],
      "@sigx/ssr-islands": ["./packages/ssr-islands/src/index.ts"],
      "@sigx/ssr-islands/server": ["./packages/ssr-islands/src/server/index.ts"],
      "@sigx/ssr-islands/client": ["./packages/ssr-islands/src/client/index.ts"],
      "@sigx/ssr-islands/jsx": ["./packages/ssr-islands/src/jsx.d.ts"],
      "sigx": ["./packages/sigx/src/index.ts"],
      "sigx/internals": ["./packages/sigx/src/internals.ts"],
      "sigx/jsx-runtime": ["./packages/sigx/src/index.ts"],
      "sigx/jsx-dev-runtime": ["./packages/sigx/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/__tests__/**/*.ts",
    "packages/*/__tests__/**/*.tsx"
  ],
  "exclude": ["node_modules", "**/dist", "examples"]
}
