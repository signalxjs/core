{
    "name": "sigx-core",
    "private": true,
    "packageManager": "pnpm@10.33.4",
    "description": "SignalX core - reactivity, runtime-core, runtime-dom, sigx, server-renderer and Vite plugin",
    "type": "module",
    "workspaces": [
        "packages/*",
        "examples",
        "examples/*",
        "benchmarks"
    ],
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "bench": "vitest bench --run",
        "bench:json": "vitest bench --run --outputJson bench-results.json",
        "bench:compare": "vitest bench --run --compare bench-results.json",
        "bench:ssr": "pnpm --filter @sigx/benchmarks bench",
        "bench:ssr:stream": "pnpm --filter @sigx/benchmarks bench:stream",
        "bench:micro": "pnpm --filter @sigx/benchmarks bench:micro",
        "bench:ssr:quick": "pnpm --filter @sigx/benchmarks bench:quick",
        "bench:ssr:baseline": "pnpm --filter @sigx/benchmarks bench:baseline",
        "build": "pnpm run build:core && pnpm --filter @sigx/server-renderer run build && pnpm --filter @sigx/ssr-islands run build && pnpm --filter @sigx/resume run build && pnpm --filter @sigx/cache run build && pnpm --filter @sigx/server run build && pnpm --filter @sigx/vite run build && pnpm --filter @sigx/cloudflare run build && pnpm --filter @sigx/vercel run build && pnpm --filter @sigx/netlify run build",
        "build:core": "pnpm --filter @sigx/serialize run build && pnpm --filter @sigx/reactivity run build && pnpm --filter @sigx/runtime-core run build && pnpm --filter @sigx/runtime-dom run build && pnpm --filter sigx run build",
        "build:sigx": "pnpm --filter sigx run build",
        "build:vite": "pnpm --filter @sigx/vite run build",
        "build:ssr-islands": "pnpm --filter @sigx/ssr-islands run build",
        "build:resume": "pnpm --filter @sigx/resume run build",
        "build:server-renderer": "pnpm --filter @sigx/server-renderer run build",
        "build:server": "pnpm --filter @sigx/server run build",
        "dev:sigx": "pnpm --filter sigx run dev",
        "dev:vite": "pnpm --filter @sigx/vite run dev",
        "typecheck": "tsc --noEmit",
        "typecheck:examples": "node scripts/typecheck-examples.mjs",
        "lint": "oxlint --deny-warnings packages/serialize/src packages/reactivity/src packages/runtime-core/src packages/runtime-dom/src packages/sigx/src packages/server-renderer/src packages/ssr-islands/src packages/resume/src packages/cache/src packages/server/src packages/vite/src packages/cloudflare/src packages/vercel/src packages/netlify/src",
        "lint:fix": "oxlint --fix packages/serialize/src packages/reactivity/src packages/runtime-core/src packages/runtime-dom/src packages/sigx/src packages/server-renderer/src packages/ssr-islands/src packages/resume/src packages/cache/src packages/server/src packages/vite/src packages/cloudflare/src packages/vercel/src packages/netlify/src",
        "publish:dry": "node scripts/publish.js --dry-run",
        "publish:all": "node scripts/publish.js",
        "publish:beta": "node scripts/publish.js --tag beta",
        "verify:pack": "node scripts/verify-pack.js",
        "verify:ecosystem": "node scripts/check-ecosystem.mjs",
        "verify:orchestrator": "node scripts/check-orchestrator.mjs",
        "version:set": "node scripts/bump-version.js",
        "version:patch": "node scripts/bump-version.js patch",
        "version:minor": "node scripts/bump-version.js minor",
        "version:major": "node scripts/bump-version.js major",
        "size": "size-limit",
        "wt": "node scripts/worktree.mjs",
        "clean": "node -e \"const fs=require('fs'),p=require('path');const rm=x=>fs.rmSync(x,{recursive:true,force:true});for(const d of fs.readdirSync('packages')){rm(p.join('packages',d,'dist'));rm(p.join('packages',d,'node_modules'));}rm('node_modules');rm('pnpm-lock.yaml');\"",
        "test:edge": "node --conditions production --import ./packages/server-renderer/scripts/edge-register.mjs packages/server-renderer/scripts/edge-smoke.mjs",
        "smoke:hydration": "node scripts/hydration-smoke.mjs",
        "deploy-smoke:cloudflare": "node scripts/deploy-smoke/cloudflare.mjs",
        "deploy-smoke:node": "node scripts/deploy-smoke/node.mjs",
        "deploy-smoke:bun": "node scripts/deploy-smoke/bun.mjs",
        "deploy-smoke:deno": "node scripts/deploy-smoke/deno.mjs",
        "deploy-smoke:vercel": "node scripts/deploy-smoke/vercel.mjs",
        "deploy-smoke:netlify": "node scripts/deploy-smoke/netlify.mjs",
        "build:serialize": "pnpm --filter @sigx/serialize run build"
    },
    "devDependencies": {
        "@size-limit/preset-small-lib": "^11",
        "@vitest/coverage-v8": "^4.1.10",
        "happy-dom": "^20.11.1",
        "miniflare": "^4.20260721.0",
        "oxlint": "^1.75.0",
        "playwright": "^1.61.1",
        "size-limit": "^11",
        "typescript": "^7.0.2",
        "vite": "^8.1.5",
        "vitest": "^4.1.10"
    },
    "keywords": [
        "SignalX",
        "signals",
        "reactivity",
        "tsx",
        "framework"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/core.git"
    },
    "homepage": "https://sigx.dev/core/",
    "bugs": {
        "url": "https://github.com/signalxjs/core/issues"
    }
}
