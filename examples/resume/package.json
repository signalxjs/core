{
    "name": "@sigx/resume-example",
    "version": "0.1.0",
    "private": true,
    "description": "Resumability example — zero-JS page, QRL handlers on first interaction, upgrade-on-write",
    "type": "module",
    "scripts": {
        "dev": "node server.mjs",
        "build": "vite build --app",
        "start": "cross-env NODE_ENV=production node --conditions production server.mjs",
        "build:cloudflare": "vite build --app -c vite.config.cloudflare.ts"
    },
    "dependencies": {
        "sigx": "workspace:^",
        "@sigx/server-renderer": "workspace:^",
        "@sigx/resume": "workspace:^",
        "@sigx/server": "workspace:^",
        "@sigx/reactivity": "workspace:^",
        "@sigx/runtime-core": "workspace:^",
        "@sigx/runtime-dom": "workspace:^",
        "express": "^5.2.1"
    },
    "devDependencies": {
        "@sigx/cloudflare": "workspace:^",
        "@sigx/vite": "workspace:^",
        "@types/express": "^5.0.6",
        "@types/node": "^26.1.1",
        "cross-env": "^10.1.0",
        "typescript": "^7.0.2",
        "vite": "^8.1.4"
    }
}
