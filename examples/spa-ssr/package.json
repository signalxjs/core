{
    "name": "@sigx/spa-ssr-example",
    "version": "0.1.0",
    "private": true,
    "description": "Server-rendered SignalX SPA with Express and client hydration",
    "type": "module",
    "scripts": {
        "dev": "node server.mjs",
        "build": "vite build --app",
        "start": "cross-env NODE_ENV=production node --conditions production server.mjs"
    },
    "dependencies": {
        "sigx": "workspace:^",
        "@sigx/server-renderer": "workspace:^",
        "@sigx/reactivity": "workspace:^",
        "@sigx/runtime-core": "workspace:^",
        "@sigx/runtime-dom": "workspace:^",
        "express": "^5.2.1",
        "@sigx/cache": "workspace:^"
    },
    "devDependencies": {
        "@sigx/vite": "workspace:^",
        "@types/express": "^5.0.6",
        "@types/node": "^26.1.1",
        "cross-env": "^10.1.0",
        "vite": "^8.1.5",
        "typescript": "^7.0.2"
    }
}
