{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "jsxImportSource": "sigx",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "types": ["node"],
        "noEmit": true
    },
    "include": [
