{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "sigx",
    "types": [],
    "paths": {
      "sigx": ["../packages/sigx/src/index.ts"],
      "sigx/*": ["../packages/sigx/src/*"],
      "@sigx/server-renderer": ["../packages/server-renderer/src/index.ts"],
      "@sigx/runtime-core": ["../packages/runtime-core/src/index.ts"],
      "@sigx/runtime-dom": ["../packages/runtime-dom/src/index.ts"],
      "@sigx/reactivity": ["../packages/reactivity/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "../core/src/**/*.d.ts"],
  "exclude": ["node_modules", "vite.config.ts"]
}
