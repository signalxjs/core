{
    "name": "@sigx/vite",
    "version": "0.7.0",
    "description": "Vite plugin for SignalX Framework with HMR, library builds, and automatic type generation",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./hmr": {
            "types": "./dist/hmr.d.ts",
            "import": "./dist/hmr.js"
        },
        "./lib": {
            "types": "./dist/lib.d.ts",
            "import": "./dist/lib.js"
        }
    },
    "bin": {
        "sigx-types": "./dist/cli.js"
    },
    "files": [
        "dist",
        "src"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "prepublishOnly": "pnpm run build"
    },
    "peerDependencies": {
        "sigx": "*",
        "vite": ">=8.0.0"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "sigx": "workspace:^",
        "typescript": "^7.0.2",
        "vite": "^8.1.4"
    },
    "keywords": [
        "SignalX"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/core.git",
        "directory": "packages/vite"
    },
    "homepage": "https://sigx.dev/vite/",
    "bugs": {
        "url": "https://github.com/signalxjs/core/issues"
    },
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    }
}
