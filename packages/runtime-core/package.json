{
    "name": "@sigx/runtime-core",
    "version": "0.6.3",
    "description": "Runtime core for SignalX",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "development": "./dist/index.js",
            "production": "./dist/index.prod.js",
            "import": "./dist/index.js"
        },
        "./internals": {
            "types": "./dist/internals.d.ts",
            "development": "./dist/internals.js",
            "production": "./dist/internals.prod.js",
            "import": "./dist/internals.js"
        },
        "./inspect": {
            "types": "./dist/inspect.d.ts",
            "development": "./dist/inspect.js",
            "production": "./dist/inspect.prod.js",
            "import": "./dist/inspect.js"
        },
        "./jsx-runtime": {
            "types": "./dist/index.d.ts",
            "development": "./dist/index.js",
            "production": "./dist/index.prod.js",
            "import": "./dist/index.js"
        },
        "./jsx-dev-runtime": {
            "types": "./dist/index.d.ts",
            "development": "./dist/index.js",
            "production": "./dist/index.prod.js",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "vite build && vite build --mode prod-dist && tsgo --emitDeclarationOnly",
        "dev": "vite build --watch",
        "test": "tsgo --noEmit -p tsconfig.test.json && vitest run",
        "test:watch": "vitest",
        "test:types": "tsgo --noEmit -p tsconfig.test.json",
        "prepublishOnly": "pnpm run build"
    },
    "keywords": [
        "sigx",
        "runtime",
        "core",
        "components",
        "framework"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/core.git",
        "directory": "packages/runtime-core"
    },
    "homepage": "https://sigx.dev/core/packages/runtime-core/overview/",
    "bugs": {
        "url": "https://github.com/signalxjs/core/issues"
    },
    "sideEffects": false,
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "dependencies": {
        "@sigx/reactivity": "workspace:^"
    },
    "devDependencies": {
        "@sigx/vite": "workspace:^",
        "@types/node": "^25.9.3",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.9"
    }
}
