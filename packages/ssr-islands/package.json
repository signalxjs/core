{
    "name": "@sigx/ssr-islands",
    "version": "0.13.0",
    "description": "Islands architecture for SignalX SSR — selective hydration via client:* directives",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "development": "./dist/index.js",
            "production": "./dist/index.prod.js",
            "import": "./dist/index.js"
        },
        "./server": {
            "types": "./dist/server/index.d.ts",
            "development": "./dist/server/index.js",
            "production": "./dist/server/index.prod.js",
            "import": "./dist/server/index.js"
        },
        "./client": {
            "types": "./dist/client/index.d.ts",
            "development": "./dist/client/index.js",
            "production": "./dist/client/index.prod.js",
            "import": "./dist/client/index.js"
        },
        "./jsx": {
            "types": "./src/jsx.d.ts"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "vite build && vite build --mode prod-dist && tsc --emitDeclarationOnly",
        "dev": "vite build --watch",
        "prepublishOnly": "pnpm run build"
    },
    "keywords": [
        "sigx",
        "ssr",
        "islands",
        "hydration",
        "selective-hydration",
        "client-directives",
        "server-side-rendering"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/core.git",
        "directory": "packages/ssr-islands"
    },
    "homepage": "https://sigx.dev/server/",
    "bugs": {
        "url": "https://github.com/signalxjs/core/issues"
    },
    "dependencies": {
        "@sigx/server-renderer": "workspace:^",
        "sigx": "workspace:^"
    },
    "devDependencies": {
        "@sigx/vite": "workspace:^",
        "@types/node": "^26.1.1",
        "typescript": "^7.0.2",
        "vite": "^8.1.5"
    },
    "publishConfig": {
        "access": "public"
    }
}
