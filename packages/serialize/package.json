{
    "name": "@sigx/serialize",
    "version": "0.12.0",
    "description": "The boundary codec for SignalX — how Date, Map, Set, BigInt and custom types survive every server↔client boundary: the SSR state blob, resume boundary props, the cache seed, and the server-function RPC wire",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "development": "./dist/index.js",
            "production": "./dist/index.prod.js",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "vite build && vite build --mode prod-dist && tsc --emitDeclarationOnly",
        "dev": "vite build --watch",
        "prepublishOnly": "pnpm run build"
    },
    "keywords": [
        "sigx",
        "serialization",
        "hydration",
        "ssr",
        "rpc",
        "date",
        "structured-clone"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/core.git",
        "directory": "packages/serialize"
    },
    "homepage": "https://sigx.dev/",
    "bugs": {
        "url": "https://github.com/signalxjs/core/issues"
    },
    "devDependencies": {
        "@sigx/vite": "workspace:^",
        "@types/node": "^26.1.1",
        "esbuild": "^0.28.1",
        "typescript": "^7.0.2",
        "vite": "^8.1.4"
    },
    "publishConfig": {
        "access": "public"
    }
}
