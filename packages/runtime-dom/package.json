{
    "name": "@sigx/runtime-dom",
    "version": "0.4.0",
    "description": "DOM runtime for SignalX",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./internals": {
            "import": "./dist/internals.js",
            "types": "./dist/internals.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "vite build && tsgo --emitDeclarationOnly",
        "dev": "vite build --watch",
        "prepublishOnly": "pnpm run build"
    },
    "keywords": [
        "SignalX"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/core.git",
        "directory": "packages/runtime-dom"
    },
    "homepage": "https://github.com/signalxjs/core/tree/main/packages/runtime-dom",
    "bugs": {
        "url": "https://github.com/signalxjs/core/issues"
    },
    "sideEffects": [
        "./dist/index.js",
        "./dist/model-processor.js",
        "./dist/render.js"
    ],
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "dependencies": {
        "@sigx/runtime-core": "workspace:^",
        "@sigx/reactivity": "workspace:^"
    },
    "devDependencies": {
        "@sigx/vite": "workspace:^",
        "typescript": "^5.9.3",
        "vite": "^8.0.3"
    }
}
