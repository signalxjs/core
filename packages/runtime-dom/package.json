{
    "name": "@sigx/runtime-dom",
    "version": "0.6.0",
    "description": "DOM runtime for SignalX",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "development": "./dist/index.js",
            "production": "./dist/index.prod.js",
            "import": "./dist/index.js"
        },
        "./internals": {
            "types": "./dist/internals.d.ts",
            "development": "./dist/internals.js",
            "production": "./dist/internals.prod.js",
            "import": "./dist/internals.js"
        },
        "./platform": {
            "types": "./dist/model-processor.d.ts",
            "development": "./dist/model-processor.js",
            "production": "./dist/model-processor.prod.js",
            "import": "./dist/model-processor.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "vite build && vite build --mode prod-dist && tsgo --emitDeclarationOnly",
        "dev": "vite build --watch",
        "prepublishOnly": "pnpm run build"
    },
    "keywords": [
        "SignalX"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/core.git",
        "directory": "packages/runtime-dom"
    },
    "homepage": "https://sigx.dev/core/packages/runtime-dom/overview/",
    "bugs": {
        "url": "https://github.com/signalxjs/core/issues"
    },
    "sideEffects": [
        "./src/model-processor.ts",
        "./src/render.ts",
        "./dist/model-processor.js",
        "./dist/model-processor.prod.js"
    ],
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "dependencies": {
        "@sigx/runtime-core": "workspace:^",
        "@sigx/reactivity": "workspace:^"
    },
    "devDependencies": {
        "@sigx/vite": "workspace:^",
        "@types/node": "^25.9.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.14"
    }
}
