{
    "name": "@sigx/benchmarks",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "description": "Comparative SSR benchmarks: sigx vs Vue vs React vs Preact",
    "scripts": {
        "bench": "node src/verify-equivalence.ts && node src/run-all.ts",
        "bench:stream": "node src/run-stream.ts",
        "bench:baseline": "node src/run-all.ts --baseline && node src/run-stream.ts --baseline",
        "verify": "node src/verify-equivalence.ts"
    },
    "devDependencies": {
        "@sigx/server-renderer": "workspace:*",
        "@types/node": "^25.9.1",
        "@vue/server-renderer": "^3.5.0",
        "mitata": "^1.0.0",
        "preact": "^10.25.0",
        "preact-render-to-string": "^6.5.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "sigx": "workspace:*",
        "vue": "^3.5.0"
    }
}
